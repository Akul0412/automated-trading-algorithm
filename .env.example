# =============================================
# Automated Stock Trading Bot — Configuration
# =============================================
# Copy this file to .env and edit with your Alpaca API keys.
# Run: python main.py --live       (real orders)
# Run: python main.py --dry-run    (simulation, no broker needed)

# --- Alpaca API Keys ---
# Get these from https://app.alpaca.markets/paper/dashboard/overview
# (Paper keys for testing, then switch to live keys when ready)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Paper mode: True = paper trading (fake money), False = real money
# Start with True, switch to False when you're confident
ALPACA_PAPER=True

# --- Order Type ---
# MOC = Market-on-Close (fills at 4:00 PM close auction)
# MKT = Market order (fills immediately — required for fractional shares)
ORDER_TYPE=MKT

# --- Capital / Sizing ---
FIRST_WEEK_BUY_CAP=300
MAX_PER_STOCK=30
MIN_PRICE=5
CASH_BUFFER_PCT=0.05

# --- Risk ---
DRAWDOWN_LIMIT=0.10

# --- Regime Filter (SPY 5-day return bounds) ---
REGIME_LOW=-0.01
REGIME_HIGH=0.01

# --- Buy Signals ---
BUY_THRESHOLD=-0.05
LOOKBACK_DAYS=5
MA_PERIOD=50
MAX_BUY_CANDIDATES=10

# --- Sell Signals (position-based) ---
PROFIT_TARGET=0.05
STOP_LOSS=-0.10
MAX_HOLD_WEEKS=2

# --- Database ---
DB_PATH=trading_bot.db
